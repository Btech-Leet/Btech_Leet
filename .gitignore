# ========================================
# BTech LEET – Root Git Ignore
# ========================================

# Dependencies
app/node_modules/
app/.pnp
app/.pnp.*
app/.yarn/*
!app/.yarn/patches
!app/.yarn/plugins
!app/.yarn/releases
!app/.yarn/versions

# Testing
app/coverage/

# Next.js build output
app/.next/
app/out/

# Production build
app/build/
app/dist/

# Environment variables (NEVER commit secrets)
app/.env
app/.env.*
!app/.env.example

# Misc
.DS_Store
*.pem
Thumbs.db
*.swp
*.swo
*~

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
app/.vercel/

# TypeScript build artifacts
app/*.tsbuildinfo
app/next-env.d.ts

# Prisma generated client
app/src/generated/

# IDE / Editor
.vscode/settings.json
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Agents / AI tooling
app/.agents/
app/skills-lock.json

# Bun lock (using npm)
app/bun.lock

# Env file copy
app/env
