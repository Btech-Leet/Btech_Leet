generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
  EDITOR
}

enum ExamType {
  STATE
  CENTRAL
  PRIVATE
}

enum PaperType {
  PREVIOUS_YEAR
  MOCK
  SAMPLE
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MockTestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

// ─── User ────────────────────────────────────────────────────
model User {
  id                String          @id @default(cuid())
  name              String
  email             String          @unique
  password          String
  role              Role            @default(USER)
  emailVerified     Boolean         @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  avatar            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  subscriptions     EmailSubscription[]
  testAttempts      TestAttempt[]
  savedPapers       SavedPaper[]
  bookmarkedBlogs   BlogBookmark[]

  @@map("users")
}

// ─── State ───────────────────────────────────────────────────
model State {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())

  exams     Exam[]
  colleges  College[]

  @@map("states")
}

// ─── Exam ────────────────────────────────────────────────────
model Exam {
  id               String     @id @default(cuid())
  name             String
  fullName         String
  slug             String     @unique
  type             ExamType
  stateId          String?
  description      String?    @db.Text
  officialWebsite  String?
  applicationFee   String?
  eligibility      String?    @db.Text
  importantDates   Json?
  syllabus         Json?
  examPattern      Json?
  contactInfo      Json?
  featured         Boolean    @default(false)
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  state            State?     @relation(fields: [stateId], references: [id])
  papers           Paper[]
  notifications    Notification[]
  counselling      Counselling[]

  @@map("exams")
}

// ─── Paper ───────────────────────────────────────────────────
model Paper {
  id          String      @id @default(cuid())
  title       String
  examId      String
  year        Int?
  type        PaperType
  subject     String?
  branch      String?
  fileUrl     String
  fileKey     String
  fileSize    Int?
  mimeType    String?
  downloads   Int         @default(0)
  views       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  savedBy     SavedPaper[]

  @@map("papers")
}

model SavedPaper {
  id        String   @id @default(cuid())
  userId    String
  paperId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([userId, paperId])
  @@map("saved_papers")
}

// ─── Notification ─────────────────────────────────────────────
model Notification {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  examId      String?
  priority    NotificationPriority @default(MEDIUM)
  published   Boolean              @default(true)
  pinned      Boolean              @default(false)
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  exam        Exam?                @relation(fields: [examId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

// ─── Counselling ─────────────────────────────────────────────
model Counselling {
  id              String   @id @default(cuid())
  examId          String
  title           String
  description     String?  @db.Text
  schedule        Json?
  rounds          Json?
  documents       Json?
  helplineNumbers Json?
  officialPortal  String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("counsellings")
}

// ─── College ──────────────────────────────────────────────────
model College {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  stateId       String?
  city          String?
  type          String?
  affiliation   String?
  website       String?
  logo          String?
  description   String?   @db.Text
  accreditation String?
  ranking       Int?
  established   Int?
  featured      Boolean   @default(false)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  state         State?    @relation(fields: [stateId], references: [id], onDelete: SetNull)
  branches      CollegeBranch[]

  @@map("colleges")
}

// ─── Branch ───────────────────────────────────────────────────
model Branch {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  description String?   @db.Text
  createdAt   DateTime  @default(now())

  colleges    CollegeBranch[]
  resources   Resource[]

  @@map("branches")
}

model CollegeBranch {
  id          String   @id @default(cuid())
  collegeId   String
  branchId    String
  intake      Int?
  fees        String?
  duration    String?

  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([collegeId, branchId])
  @@map("college_branches")
}

// ─── Resource ─────────────────────────────────────────────────
model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  branchId    String?
  subject     String?
  semester    Int?
  type        String
  fileUrl     String
  fileKey     String
  fileSize    Int?
  mimeType    String?
  downloads   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("resources")
}

// ─── Blog ─────────────────────────────────────────────────────
model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts     BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  content     String     @db.Text
  coverImage  String?
  categoryId  String?
  tags        String[]
  status      PostStatus @default(DRAFT)
  featured    Boolean    @default(false)
  views       Int        @default(0)
  readTime    Int?
  metaTitle   String?
  metaDesc    String?    @db.Text
  authorName  String?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  category    BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bookmarks   BlogBookmark[]

  @@map("blog_posts")
}

model BlogBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("blog_bookmarks")
}

// ─── Mock Tests ───────────────────────────────────────────────
model MockTest {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?        @db.Text
  examId      String?
  duration    Int
  totalMarks  Int
  passMark    Int?
  status      MockTestStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  questions   Question[]
  attempts    TestAttempt[]

  @@map("mock_tests")
}

model Question {
  id           String       @id @default(cuid())
  testId       String
  text         String       @db.Text
  type         QuestionType @default(MCQ)
  options      Json?
  answer       String
  explanation  String?      @db.Text
  marks        Int          @default(1)
  order        Int          @default(0)
  createdAt    DateTime     @default(now())

  test         MockTest     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model TestAttempt {
  id          String   @id @default(cuid())
  userId      String
  testId      String
  answers     Json
  score       Int
  totalMarks  Int
  timeTaken   Int?
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test        MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("test_attempts")
}

// ─── Email Subscriptions ─────────────────────────────────────
model EmailSubscription {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  name      String?
  tags      String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email])
  @@map("email_subscriptions")
}

// ─── Site Settings ────────────────────────────────────────────
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
